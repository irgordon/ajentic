{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ajentic.dev/schemas/memory/memory-snapshot.schema.json",
  "title": "Memory Snapshot",
  "description": "Snapshot of memory state.",
  "type": "object",
  "required": [
    "schema_version",
    "snapshot_id",
    "created_at",
    "entries"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "snapshot_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "schema_version",
          "memory_id",
          "memory_type",
          "content",
          "provenance",
          "status"
        ],
        "properties": {
          "schema_version": {
            "type": "string",
            "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
          },
          "memory_id": {
            "type": "string",
            "minLength": 1
          },
          "memory_type": {
            "type": "string",
            "enum": [
              "project_fact",
              "convention",
              "operator_note",
              "run_observation",
              "disabled"
            ]
          },
          "content": {
            "type": "object"
          },
          "provenance": {
            "type": "object",
            "required": [
              "schema_version",
              "source",
              "created_by",
              "created_at",
              "reason"
            ],
            "properties": {
              "schema_version": {
                "type": "string",
                "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
              },
              "source": {
                "type": "string",
                "minLength": 1
              },
              "created_by": {
                "type": "string",
                "minLength": 1
              },
              "created_at": {
                "type": "string",
                "format": "date-time"
              },
              "reason": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "disabled",
              "rejected"
            ]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
