{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ajentic.dev/schemas/traces/run-trace.schema.json",
  "title": "Run Trace",
  "description": "Run trace projection shape.",
  "type": "object",
  "required": [
    "schema_version",
    "trace_id",
    "run_id",
    "events",
    "validation_reports",
    "replay_reports",
    "summary"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "validation_reports": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "schema_version",
          "validation_report_id",
          "run_id",
          "status",
          "checks",
          "summary"
        ],
        "properties": {
          "schema_version": {
            "type": "string",
            "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
          },
          "validation_report_id": {
            "type": "string",
            "minLength": 1
          },
          "run_id": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "pass",
              "fail",
              "blocked",
              "unknown"
            ]
          },
          "checks": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "check_id",
                "status",
                "message"
              ],
              "properties": {
                "check_id": {
                  "type": "string",
                  "minLength": 1
                },
                "status": {
                  "type": "string",
                  "enum": [
                    "pass",
                    "fail",
                    "blocked",
                    "unknown"
                  ]
                },
                "message": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "additionalProperties": false
            }
          },
          "summary": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "replay_reports": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "schema_version",
          "replay_report_id",
          "run_id",
          "status",
          "integrity",
          "events_replayed",
          "summary"
        ],
        "properties": {
          "schema_version": {
            "type": "string",
            "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
          },
          "replay_report_id": {
            "type": "string",
            "minLength": 1
          },
          "run_id": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "replayable",
              "not_replayable",
              "failed",
              "unknown"
            ]
          },
          "integrity": {
            "type": "string",
            "enum": [
              "valid",
              "invalid",
              "incomplete",
              "conflicting",
              "unknown"
            ]
          },
          "events_replayed": {
            "type": "integer",
            "minimum": 0
          },
          "summary": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "summary": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false
}
