{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ajentic.dev/schemas/traces/validation-report.schema.json",
  "title": "Validation Report",
  "description": "Validation result report.",
  "type": "object",
  "required": [
    "schema_version",
    "validation_report_id",
    "run_id",
    "status",
    "checks",
    "summary"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "validation_report_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "fail",
        "blocked",
        "unknown"
      ]
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "check_id",
          "status",
          "message"
        ],
        "properties": {
          "check_id": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "pass",
              "fail",
              "blocked",
              "unknown"
            ]
          },
          "message": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "summary": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false
}
