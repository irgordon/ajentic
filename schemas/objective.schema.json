{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Objective Contract",
  "description": "Phase 1 objective boundary contract shape.",
  "type": "object",
  "required": [
    "id",
    "domain_id",
    "objective_type",
    "description",
    "success_criteria",
    "constraints_ref",
    "evaluation_profile_ref"
  ],
  "properties": {
    "id": { "type": "string" },
    "domain_id": { "type": "string" },
    "objective_type": { "type": "string" },
    "description": { "type": "string" },
    "success_criteria": { "type": "array", "items": { "type": "string" } },
    "constraints_ref": { "type": "string" },
    "evaluation_profile_ref": { "type": "string" }
  },
  "additionalProperties": false
}
