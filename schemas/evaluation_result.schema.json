{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Evaluation Result Contract",
  "description": "Phase 1 evaluation result boundary contract shape.",
  "type": "object",
  "required": [
    "id",
    "candidate_solution_id",
    "evaluator_id",
    "status",
    "checked_constraints",
    "threshold_results",
    "evidence_ref",
    "failure_reasons"
  ],
  "properties": {
    "id": { "type": "string" },
    "candidate_solution_id": { "type": "string" },
    "evaluator_id": { "type": "string" },
    "status": { "type": "string", "enum": ["PASS", "FAIL", "BLOCKED", "UNKNOWN"] },
    "checked_constraints": { "type": "array", "items": { "type": "string" } },
    "threshold_results": { "type": "array", "items": { "type": "string" } },
    "evidence_ref": { "type": "string" },
    "failure_reasons": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
