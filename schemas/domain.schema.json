{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Domain Contract",
  "description": "Phase 1 domain boundary contract shape.",
  "type": "object",
  "required": [
    "id",
    "name",
    "objective_types",
    "constraint_types",
    "evaluators",
    "known_failure_modes",
    "promotion_thresholds"
  ],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "objective_types": { "type": "array", "items": { "type": "string" } },
    "constraint_types": { "type": "array", "items": { "type": "string" } },
    "evaluators": { "type": "array", "items": { "type": "string" } },
    "known_failure_modes": { "type": "array", "items": { "type": "string" } },
    "promotion_thresholds": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
