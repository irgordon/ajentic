{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Candidate Solution Contract",
  "description": "Phase 1 candidate solution boundary contract shape.",
  "type": "object",
  "required": [
    "id",
    "run_id",
    "domain_id",
    "objective_id",
    "constraints_id",
    "content_ref",
    "generation_metadata_ref",
    "lifecycle_state",
    "evaluation_results_ref",
    "governance_results_ref"
  ],
  "properties": {
    "id": { "type": "string" },
    "run_id": { "type": "string" },
    "domain_id": { "type": "string" },
    "objective_id": { "type": "string" },
    "constraints_id": { "type": "string" },
    "content_ref": { "type": "string" },
    "generation_metadata_ref": { "type": "string" },
    "lifecycle_state": {
      "type": "string",
      "enum": [
        "CREATED",
        "EVALUATING",
        "FAILED",
        "BLOCKED",
        "PASSED",
        "PROMOTED_TIER_1",
        "REJECTED",
        "UNKNOWN"
      ]
    },
    "evaluation_results_ref": { "type": "array", "items": { "type": "string" } },
    "governance_results_ref": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
