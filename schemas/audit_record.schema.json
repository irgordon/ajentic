{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Audit Record Contract",
  "description": "Phase 1 audit record boundary contract shape.",
  "type": "object",
  "required": [
    "id",
    "run_id",
    "objective_id",
    "constraints_id",
    "domain_id",
    "candidate_solution_ids",
    "evaluation_result_ids",
    "governance_result_ids",
    "promotion_decision_ids",
    "final_status"
  ],
  "properties": {
    "id": { "type": "string" },
    "run_id": { "type": "string" },
    "objective_id": { "type": "string" },
    "constraints_id": { "type": "string" },
    "domain_id": { "type": "string" },
    "candidate_solution_ids": { "type": "array", "items": { "type": "string" } },
    "evaluation_result_ids": { "type": "array", "items": { "type": "string" } },
    "governance_result_ids": { "type": "array", "items": { "type": "string" } },
    "promotion_decision_ids": { "type": "array", "items": { "type": "string" } },
    "final_status": { "type": "string", "enum": ["PASS", "FAIL", "BLOCKED", "UNKNOWN"] }
  },
  "additionalProperties": false
}
