{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ajentic.dev/schemas/events/run-event.schema.json",
  "title": "Run Event",
  "description": "Non-authoritative run event projection shape for timelines and UI display.",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "event_id",
    "event_type",
    "timestamp",
    "summary",
    "details"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "event_type": {
      "type": "string",
      "enum": [
        "run_created",
        "context_created",
        "provider_called",
        "candidate_received",
        "validation_completed",
        "policy_completed",
        "intent_received",
        "intent_resolved",
        "ledger_recorded",
        "replay_completed",
        "audit_projected",
        "output_ready",
        "run_failed",
        "run_cancelled"
      ]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "details": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
