{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ajentic.dev/schemas/context/context-budget.schema.json",
  "title": "Context Budget",
  "description": "Token or size budget metadata for context packets.",
  "type": "object",
  "required": [
    "schema_version",
    "max_units",
    "used_units",
    "unit"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "max_units": {
      "type": "integer",
      "minimum": 0
    },
    "used_units": {
      "type": "integer",
      "minimum": 0
    },
    "unit": {
      "type": "string",
      "enum": [
        "tokens",
        "bytes",
        "characters"
      ]
    }
  },
  "additionalProperties": false
}
