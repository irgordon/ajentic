{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Reuse Event Contract",
  "description": "Phase 1 reuse event boundary contract shape.",
  "type": "object",
  "required": [
    "id",
    "source_run_id",
    "source_pattern_ref",
    "target_run_id",
    "target_domain_id",
    "reuse_type",
    "validation_status",
    "mismatch_notes"
  ],
  "properties": {
    "id": { "type": "string" },
    "source_run_id": { "type": "string" },
    "source_pattern_ref": { "type": "string" },
    "target_run_id": { "type": "string" },
    "target_domain_id": { "type": "string" },
    "reuse_type": {
      "type": "string",
      "enum": [
        "STRATEGY",
        "STRUCTURE",
        "EVALUATOR_ORDER",
        "PROMPT_PATTERN",
        "REPAIR_PATTERN"
      ]
    },
    "validation_status": { "type": "string", "enum": ["PASS", "FAIL", "BLOCKED", "UNKNOWN"] },
    "mismatch_notes": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
